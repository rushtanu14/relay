{
  "name": "relay",
  "version": "0.1.0",
  "private": true,
  "description": "Relay turns pasted meeting notes into a personal follow-up dashboard.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
